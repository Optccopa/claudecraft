{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug claudecraft",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/claudecraft.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "build (debug)"
        },
        {
            "name": "Run claudecraft (release)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/release/claudecraft.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "build (release)"
        }
    ]
}
